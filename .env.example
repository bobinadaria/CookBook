# Public site URL — used for canonical links and OpenGraph metadata
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_public_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Google AI (Gemini) — used for auto-translating recipes
GOOGLE_AI_API_KEY=your_google_ai_key_here

# OpenAI — used for AI cover image generation (DALL-E 3)
OPENAI_API_KEY=your_openai_api_key_here

# Monetization feature flag — when "true", plan limits are enforced
# (e.g. Free user recipe limit). Leave unset / "false" pre-launch.
MONETIZATION_ENABLED=false

# ── Stripe ────────────────────────────────────────────────────────────────────
# Payments feature flag — when "true", real Stripe checkout is used.
# Set to "true" only after adding all STRIPE_* keys below.
NEXT_PUBLIC_PAYMENTS_ENABLED=false

# Stripe API keys — get from https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_...) locally, live keys (sk_live_...) in production.
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Stripe webhook signing secret — get from Dashboard → Webhooks → your endpoint
# For local dev: run `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
# and use the whsec_... key it prints.
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Price IDs — create products in Dashboard → Products, copy price IDs.
# Each env (test/live) has its own price IDs.
STRIPE_PRICE_PREMIUM_MONTHLY=price_your_premium_monthly_id
STRIPE_PRICE_LIFETIME=price_your_lifetime_id
STRIPE_PRICE_PACK_S=price_your_pack_s_id
STRIPE_PRICE_PACK_M=price_your_pack_m_id
STRIPE_PRICE_PACK_L=price_your_pack_l_id

# USDA FoodData Central — same key already used by scripts/seed-ingredients.mjs.
# Now also powers /admin/ingredients/new (search real USDA data before falling
# back to manual entry). Free key, instant, no payment:
# https://fdc.nal.usda.gov/api-key-signup.html
USDA_API_KEY=your_usda_api_key_here
